---
// Achievements.astro - Displays achievements, publications, and other accomplishments
---

<div class="mt-8">
  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <div class="achievement-item p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
      <h3 class="text-lg font-bold text-gray-800 dark:text-white">
        <span class="text-yellow-500 dark:text-yellow-400">📝</span> ICRAIC 2024 Publication
      </h3>
      <p class="mt-2 text-gray-600 dark:text-gray-300">
        "Enhancing Human Detection and Counting Efficiency..." (Maheshwari et al.)
      </p>
    </div>

    <div class="achievement-item p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
      <h3 class="text-lg font-bold text-gray-800 dark:text-white">
        <span class="text-yellow-500 dark:text-yellow-400">🎤</span> Invited Speaker
      </h3>
      <p class="mt-2 text-gray-600 dark:text-gray-300">
        IEEE AI Talk "AI Frontiers: RAG, GANs & YOLO" (150+ attendees)
      </p>
    </div>
    
    <div class="achievement-item p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
      <h3 class="text-lg font-bold text-gray-800 dark:text-white">
        <span class="text-yellow-500 dark:text-yellow-400">🏆</span> Meesho Data Challenge 2024
      </h3>
      <p class="mt-2 text-gray-600 dark:text-gray-300">
        23ᵗʰ place out of 196 teams
      </p>
    </div>

    <div class="achievement-item p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
      <h3 class="text-lg font-bold text-gray-800 dark:text-white">
        <span class="text-yellow-500 dark:text-yellow-400">🏅</span> Amazon ML Challenge
      </h3>
      <p class="mt-2 text-gray-600 dark:text-gray-300">
        64ᵗʰ place out of 75,000 participants
      </p>
    </div>
    
    <div class="achievement-item p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
      <h3 class="text-lg font-bold text-gray-800 dark:text-white">
        <span class="text-yellow-500 dark:text-yellow-400">🎓</span> 2X NPTEL Topper
      </h3>
      <p class="mt-2 text-gray-600 dark:text-gray-300">
        ML & DBMS (Top 2%)
      </p>
    </div>
    
    <div class="achievement-item p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
      <h3 class="text-lg font-bold text-gray-800 dark:text-white">
        <span class="text-yellow-500 dark:text-yellow-400">💻</span> LeetCode
      </h3>
      <p class="mt-2 text-gray-600 dark:text-gray-300">
        650+ problems solved, 1750 rating, 365-day streak
      </p>
    </div>
  </div>
</div>