---
// Skills.astro - Displays technical and soft skills in a grid layout
---

<div class="mt-8">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Programming Skills -->
    <div class="skills-category p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
      <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-3">
        <span class="text-yellow-500 dark:text-yellow-400">💻</span> Programming
      </h3>
      <ul class="list-disc list-inside space-y-1 text-gray-600 dark:text-gray-300">
        <li>Python</li>
        <li>C/C++</li>
        <li>R</li>
        <li>SQL</li>
        <li>Java</li>
      </ul>
    </div>

    <!-- Frameworks/Libraries Skills -->
    <div class="skills-category p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
      <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-3">
        <span class="text-yellow-500 dark:text-yellow-400">🛠️</span> Frameworks/Libraries
      </h3>
      <ul class="list-disc list-inside space-y-1 text-gray-600 dark:text-gray-300">
        <li>TensorFlow</li>
        <li>PyTorch</li>
        <li>Keras</li>
        <li>OpenCV</li>
        <li>NLTK</li>
        <li>Hugging Face</li>
        <li>Docker</li>
        <li>LangChain</li>
      </ul>
    </div>

    <!-- Technologies Skills -->
    <div class="skills-category p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
      <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-3">
        <span class="text-yellow-500 dark:text-yellow-400">🔬</span> Technologies
      </h3>
      <ul class="list-disc list-inside space-y-1 text-gray-600 dark:text-gray-300">
        <li>Computer Vision</li>
        <li>NLP</li>
        <li>Generative AI</li>
        <li>Data Visualization</li>
      </ul>
    </div>

    <!-- Soft Skills -->
    <div class="skills-category p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
      <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-3">
        <span class="text-yellow-500 dark:text-yellow-400">🤝</span> Soft Skills
      </h3>
      <ul class="list-disc list-inside space-y-1 text-gray-600 dark:text-gray-300">
        <li>Problem-Solving</li>
        <li>Decision-Making</li>
        <li>Communication</li>
        <li>Collaboration</li>
      </ul>
    </div>
  </div>
</div>