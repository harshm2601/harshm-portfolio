---
const personalImageAlt = "Harsh Maheshwari"
import Badge from "@/components/Badge.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import GitHub from "@/components/icons/GitHub.astro"
import CodeIcon from "@/components/icons/Code.astro"
import SocialPill from "@/components/SocialPill.astro"
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full shadow-lg size-16"
      src="/image.png"
      alt={personalImageAlt}
    />
    <a
      href="https://charusat.ac.in/"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>B.Tech AI & ML @ CHARUSAT</Badge>
    </a>
  </div>
  <h1
    class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
  >
    Hi, I'm Harsh Maheshwari
  </h1>
  <p
    class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"
  >
    B.Tech student specializing in <strong
      >Computer Vision, NLP, and Generative AI</strong
    > from Deesa, Gujarat, India 🇮🇳. Passionate about building data-driven solutions that solve real-world problems.
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href="mailto:harshmaheshwari219@gmail.com">
      <MailIcon class="size-4" />
      Contact Me
    </SocialPill>
    <SocialPill href="https://www.linkedin.com/in/harsh-maheshwari-29b725257/">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href="https://github.com/harshm2601">
      <GitHub class="size-4" />
      GitHub
    </SocialPill>
    <SocialPill href="https://leetcode.com/harshism">
      <CodeIcon class="size-4" />
      LeetCode
    </SocialPill>
  </nav>
</div>
